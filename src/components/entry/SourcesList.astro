---
interface SourceItem {
  label: string;
  url: string;
}

interface Props {
  items?: SourceItem[];
}

const { items = [] }: Props = Astro.props;
---

<section class="my-8 border-t border-rule pt-4">
  <h2 class="ui-meta text-[11px] uppercase tracking-[0.14em] text-dim">Sources</h2>
  <ul class="mt-3 space-y-1 text-[16px]">
    {
      items.map((item) => (
        <li>
          <a href={item.url} target="_blank" rel="noreferrer">
            {item.label}
          </a>
        </li>
      ))
    }
  </ul>
</section>

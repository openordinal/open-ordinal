---
const { label, value, note = "" } = Astro.props;
---

<div class="my-6 border border-rule p-4">
  <p class="ui-meta text-[10px] uppercase tracking-[0.16em] text-dim">{label}</p>
  <p class="mt-2 text-[36px] leading-none text-ink">{value}</p>
  {note && <p class="ui-meta mt-2 text-[11px] text-dim">{note}</p>}
</div>

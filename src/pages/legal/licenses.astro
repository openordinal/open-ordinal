---
import Layout from "../../components/layout/Layout.astro";
---

<Layout
  title="Licenses"
  description="Code and content licenses for Open Ordinal."
  lang="en"
  canonical="https://openordinal.org/legal/licenses"
>
  <section class="archive-shell entry-prose">
    <h1 class="text-[46px] leading-tight text-ink">Licenses</h1>

    <p class="ui-meta text-[11px] uppercase tracking-[0.14em] text-dim">Last updated: 2026-03-03</p>

    <h2>License summary</h2>
    <ul>
      <li>Code: MIT</li>
      <li>Content and data: CC BY 4.0</li>
    </ul>

    <h2>Attribution format</h2>
    <p>Use: <code>Open Ordinal / openordinal.org (CC BY 4.0)</code>.</p>

    <h2>Third-party components</h2>
    <p>Third-party software and services referenced by this project remain under their own licenses and terms.</p>

    <h2>License files</h2>
    <ul>
      <li><a href="https://github.com/openordinal/open-ordinal/blob/main/LICENSE-code.txt" target="_blank" rel="noreferrer">MIT license file</a></li>
      <li><a href="https://github.com/openordinal/open-ordinal/blob/main/LICENSE-content.txt" target="_blank" rel="noreferrer">CC BY 4.0 license file</a></li>
      <li><a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noreferrer">CC BY 4.0 legal code</a></li>
    </ul>
  </section>
</Layout>
